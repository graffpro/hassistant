# UE5 AI Assistant — конфигурация
# Скопируй в .env и настрой под себя

# LLM модель (qwen2.5:7b рекомендуется)
LLM_MODEL=qwen2.5:7b
LLM_HOST=http://localhost:11434

# Режим отладки (True показывает подробные логи)
DEBUG=False

# Тема интерфейса
UI_THEME=dark

# Офлайн режим (True = не использовать интернет)
OFFLINE_MODE=False
